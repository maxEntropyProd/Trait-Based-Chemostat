Cell["\<\
For a single ASVs (this evaluation has been removed from the notebook)\
\>", "Text",ExpressionUUID->"e8acc671-2a0a-4282-b68a-b0f10688ebfd"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "[", "i", "]"}], "[", "t", "]"}], "/.", "soln500beta"}], 
      "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0.71", ",", "24"}], "}"}], ",", 
     RowBox[{"PlotLabel", "\[Rule]", 
      RowBox[{"\"\<ASV: \>\"", "<>", 
       RowBox[{"ToString", "[", "i", "]"}]}]}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"i", ",", "1", ",", "500", ",", "1"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[175]:=",ExpressionUUID->"2068bfda-5dce-42ea-bab3-1bdb6281a8c2"],


     RowBox[{"vG", "\[Rule]", 
      RowBox[{"4.74", "/", "1000"}]}], ",", 
     RowBox[{"(*", 
      SuperscriptBox["m", "3"], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"fG", "\[Rule]", 
      RowBox[{"15.72", "/", "1000"}]}], ",", 
     RowBox[{"(*", 
      RowBox[{
       SuperscriptBox["m", "3"], " ", 
       SuperscriptBox["d", 
        RowBox[{"-", "1"}]]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"vM", "->", "350"}], ",", " ", 
     RowBox[{"(*", " ", 
      SuperscriptBox["d", 
       RowBox[{"-", "1"}]], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"kM", "->", "5000"}], ",", " ", 
     RowBox[{"(*", " ", 
      RowBox[{"mmol", " ", 
       SuperscriptBox["m", "3"]}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"m", "->", "0.1"}], ",", " ", 
     RowBox[{"(*", 
      RowBox[{
       SuperscriptBox["m", "3"], " ", 
       SuperscriptBox["mmol", 
        RowBox[{"-", "1"}]], " ", 
       SuperscriptBox["d", 
        RowBox[{"-", "1"}]]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"\[Alpha]", "\[Rule]", "1.1"}], ",", "\[IndentingNewLine]", 
     RowBox[{"\[Beta]", "\[Rule]", "13.3"}]}], "}"}]}], ";"}]], "Input",

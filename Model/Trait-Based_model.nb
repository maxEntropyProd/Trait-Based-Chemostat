Cell["Look at bar plot with relative abundances > 0.1%.", "Text",ExpressionUUID->"8d7842a5-e7a5-495b-9808-7973ff69b7ec"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"asvMinAbunRel", "=", "0.1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"asvBetaMin", "=", 
    RowBox[{"Chop", "[", 
     RowBox[{
      RowBox[{"N", "[", "betaASVsRel", "]"}], ",", "asvMinAbunRel"}], "]"}]}],
    ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "this", " ", "sets", " ", "any", " ", "ASV", " ", "that", " ", "is"}], 
    " ", "<", " ", 
    RowBox[{"asvMinAbunRel", " ", "to", " ", "0"}]}], " ", "*)"}]}]}], "Input",
 CellLabel->"In[94]:=",ExpressionUUID->"bb2e3bdb-7df0-064b-a172-a64fdcdec3c8"],


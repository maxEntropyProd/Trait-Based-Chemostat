Cell[CellGroupData[{

Cell["Estimate kL based on DO observations Only", "Subsection",ExpressionUUID->"4c72354c-817b-4d5e-92b8-8507b42e80f3"],

Cell[TextData[{
 "Since we quickly equilibrated the headspace with air after driving the \
system anoxic with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "2"], TraditionalForm]],ExpressionUUID->
  "69f54f23-cacc-49fd-aaa7-946676cd5326"],
 ", the governing ODE only needs to track dissolved oxygen (DO), as the gas \
phase remains constant as it is in equilibrium with air.  Here is the \
governing equation for DO."
}], "Text",ExpressionUUID->"34837deb-c83a-4ff8-8a6d-4dcc39afd190"],

Cell[BoxData[
 RowBox[{
  RowBox[{"odesDO", "[", "input_List", "]"}], ":=", 
  RowBox[{
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"c", "'"}], "[", "t", "]"}], "\[Equal]", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"fL", 
          RowBox[{"(", 
           RowBox[{"cF", "-", 
            RowBox[{"c", "[", "t", "]"}]}], ")"}]}], "+", 
         RowBox[{"kL", " ", "a", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"p", "[", "t", "]"}], "h"}], "-", 
            RowBox[{"c", "[", "t", "]"}]}], ")"}]}]}], ")"}], "/", "vL"}]}], ",",
      "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"c", "[", "0", "]"}], "\[Equal]", "cF"}]}], "}"}], "/.", 
   "input"}]}]], "Input",
 CellLabel->"In[26]:=",ExpressionUUID->"28eb5ff6-aa65-4f90-afb3-b0ce15eb42a9"],

Cell[TextData[{
 "The Henry\[CloseCurlyQuote]s constant as a function of temperature (K) for \
oxygen (see",
 ButtonBox[" ",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://satellite.mpic.de/henry/casrn/7782-44-7"], None},
  ButtonNote->"http://satellite.mpic.de/henry/casrn/7782-44-7"],
 "https://henrys-law.org/henry/casrn/7782-44-7) in \[Mu]M ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["atm", 
    RowBox[{"-", "1"}]], TraditionalForm]],ExpressionUUID->
  "8f96b465-c8ad-4693-89a9-63f817560d18"],
 " is:"
}], "Text",ExpressionUUID->"6ab23c7e-10f7-48d3-8e36-62eb45aceab3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"hO2", "[", "tk_", "]"}], ":=", 
  RowBox[{"0.00131722", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"(", 
     RowBox[{"1700", 
      RowBox[{"(", 
       RowBox[{
        FractionBox["1", "tk"], "-", 
        FractionBox["1", "298.15"]}], ")"}]}], ")"}]], 
   SuperscriptBox["10", "6"]}]}]], "Input",
 CellLabel->"In[27]:=",ExpressionUUID->"6cfc27c5-7e39-448a-a806-929e20b2d7cf"],

Cell[TextData[{
 "Below solves the ODE and plots the solution versus the DO observations.  \
The only parameters adjusted here are the oxygen piston velocity, kL (m ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["d", 
    RowBox[{"-", "1"}]], TraditionalForm]],ExpressionUUID->
  "acb74a27-8498-4e3e-84be-b961b71d0519"],
 "), which was the objective of the experiment and the oxygen concentration \
in the atmosphere, p[t] (atm).  Note, it should not have been necessary to \
change p[t], as it should be 0.21 atm; however, our DO probe may not be \
perfectly calibrated (or perhaps the headspace still contained some of the N2 \
gas used for purging) and is reading a bit low; consequently, the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["O", "2"], TraditionalForm]],ExpressionUUID->
  "3292a9b0-1266-cb4d-949f-1ec6010b21ab"],
 " concentration was decreased to 0.177 atm in order to get a good fit.  ",
 StyleBox["The value found for the piston velocity is 1.65 m ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox["d", 
    RowBox[{"-", "1"}]], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"e4b87a8c-4281-45f4-8f05-dbaa7375923f"],
 StyleBox[", which is pretty close to the estimated value of 1.3",
  FontWeight->"Bold"],
 "."
}], "Text",
 InitializationCell->
  True,ExpressionUUID->"f19f4d93-ad9a-49f0-b196-0bf4456304d5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"c", "[", "t", "]"}], "/.", 
       RowBox[{
        RowBox[{"NDSolve", "[", 
         RowBox[{
          RowBox[{"odesDO", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"fL", "\[Rule]", "0"}], ",", 
             RowBox[{"cF", "\[Rule]", "24.7"}], ",", 
             RowBox[{"kL", "\[Rule]", 
              StyleBox["1.65",
               FontColor->RGBColor[1, 0, 0]]}], ",", 
             RowBox[{"a", "\[Rule]", 
              RowBox[{"\[Pi]", " ", 
               SuperscriptBox["0.114", "2"]}]}], ",", 
             RowBox[{"h", "\[Rule]", 
              RowBox[{"hO2", "[", "298", "]"}]}], ",", 
             RowBox[{"vL", "\[Rule]", 
              RowBox[{"3", "/", "1000"}]}], ",", 
             RowBox[{
              RowBox[{"p", "[", "t", "]"}], "\[Rule]", 
              StyleBox["0.177",
               FontColor->RGBColor[1, 0, 0]]}]}], "}"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"c", "[", "t", "]"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"t", ",", "0", ",", "10"}], "}"}]}], "]"}], "\[LeftDoubleBracket]",
         "1", "\[RightDoubleBracket]"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "0.2"}], "}"}], ",", 
     RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", 
     RowBox[{"FrameLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"\"\<Time (d)\>\"", ",", "\"\<DO (\[Mu]M)\>\""}], "}"}]}], ",", 
     RowBox[{"Frame", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"True", ",", "False"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"True", ",", "False"}], "}"}]}], "}"}]}], ",", 
     RowBox[{"PlotLegends", "\[Rule]", 
      RowBox[{"{", "\"\<Model\>\"", "}"}]}]}], "]"}], ",", 
   RowBox[{"ListPlot", "[", 
    RowBox[{"o2DataN2", ",", 
     RowBox[{"PlotStyle", "\[Rule]", "Blue"}], ",", 
     RowBox[{"PlotLegends", "\[Rule]", 
      RowBox[{"{", "\"\<Data\>\"", "}"}]}]}], "]"}], ",", 
   RowBox[{"BaseStyle", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"FontSize", "\[Rule]", "15"}], ",", 
      RowBox[{"FontWeight", "\[Rule]", "Bold"}]}], "}"}]}]}], "]"}]], "Input",
 CellLabel->"In[28]:=",ExpressionUUID->"9b0c2a34-39eb-4099-8fc8-9c97af4b6aa8"],


Cell[CellGroupData[{

Cell[TextData[{
 "Estimate ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["k", "L"], "a"}], TraditionalForm]],ExpressionUUID->
  "8817eef4-5ee3-4c3e-b4f7-d17250269a67"],
 " from data for transition from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "2"], TraditionalForm]],ExpressionUUID->
  "6bc2b0d1-a7eb-415f-b5bb-ba89de3a4206"],
 " to Air"
}], "Section",ExpressionUUID->"1eeb8779-79b8-4383-8a1d-b77eaae192a3"],

Cell[CellGroupData[{

Cell["\<\
Preliminary model testing (no need to evaluate this subsection)\
\>", "Subsection",ExpressionUUID->"ebd82fb4-6b68-417a-b85d-0860bf8fc10b"],

Cell["\<\
Simple model for dissolved oxygen, c, and partial pressure, p, in the \
chemostat based on how the chemostat design. \
\>", "Text",ExpressionUUID->"dcef2079-c4d8-4e6d-b58b-5b370ad5b172"],

Cell[BoxData[
 RowBox[{
  RowBox[{"odes", "[", "input_List", "]"}], ":=", 
  RowBox[{
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"c", "'"}], "[", "t", "]"}], "\[Equal]", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"fL", 
          RowBox[{"(", 
           RowBox[{"cF", "-", 
            RowBox[{"c", "[", "t", "]"}]}], ")"}]}], "+", 
         RowBox[{"kL", " ", "a", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"p", "[", "t", "]"}], "h"}], "-", 
            RowBox[{"c", "[", "t", "]"}]}], ")"}]}]}], ")"}], "/", "vL"}]}], ",",
      "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"p", "'"}], "[", "t", "]"}], "\[Equal]", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"fG", 
          RowBox[{"(", 
           RowBox[{"pF", "-", 
            RowBox[{"p", "[", "t", "]"}]}], ")"}]}], "+", 
         RowBox[{"kL", " ", "a", " ", "rGas", " ", "tK", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"c", "[", "t", "]"}], "-", 
            RowBox[{
             RowBox[{"p", "[", "t", "]"}], "h"}]}], ")"}]}]}], ")"}], "/", 
       "vG"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"c", "[", "0", "]"}], "\[Equal]", "cF"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"p", "[", "0", "]"}], "\[Equal]", "0"}]}], 
    "\[IndentingNewLine]", "}"}], "/.", "input"}]}]], "Input",
 CellLabel->"In[14]:=",ExpressionUUID->"0427d057-bb60-402d-9389-88f0bb824147"],

Cell[TextData[{
 "Henry' s law for oxygen (from ",
 ButtonBox["http : // satellite.mpic.de/henry/casrn/7782 - 44 - 7",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://satellite.mpic.de/henry/casrn/7782-44-7"], None},
  ButtonNote->"http://satellite.mpic.de/henry/casrn/7782-44-7"],
 ")"
}], "Text",ExpressionUUID->"ee5ef10f-9777-475f-95ed-9ad347cc13ca"],

Cell[BoxData[
 RowBox[{
  RowBox[{"hO2", "[", "tk_", "]"}], ":=", 
  RowBox[{"0.00131722", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"(", 
     RowBox[{"1700", 
      RowBox[{"(", 
       RowBox[{
        FractionBox["1", "tk"], "-", 
        FractionBox["1", "298.15"]}], ")"}]}], ")"}]], 
   SuperscriptBox["10", "6"]}]}]], "Input",
 CellLabel->"In[15]:=",ExpressionUUID->"2cac1f67-97d9-46d0-a74d-996e7174bece"],

Cell["\<\
Look at a few simulations with differing kL values. Air-water area is based \
on diameter of reactor because hardly any bubbles are introduced during \
sparging.\
\>", "Text",ExpressionUUID->"eb47623f-742b-4b0e-9bbf-8d556a5a7716"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"soln1", "=", 
  RowBox[{
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"odes", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"fL", "\[Rule]", "0"}], ",", 
        RowBox[{"cF", "\[Rule]", "0"}], ",", 
        RowBox[{"kL", "\[Rule]", "0.13"}], ",", 
        RowBox[{"a", "\[Rule]", 
         RowBox[{"\[Pi]", " ", 
          SuperscriptBox["0.114", "2"]}]}], ",", 
        RowBox[{"h", "\[Rule]", 
         RowBox[{"hO2", "[", "298", "]"}]}], ",", 
        RowBox[{"vL", "\[Rule]", 
         RowBox[{"3", "/", "1000"}]}], ",", 
        RowBox[{"fG", "\[Rule]", 
         RowBox[{"15.72", "/", "1000"}]}], ",", 
        RowBox[{"pF", "\[Rule]", "0.21"}], ",", 
        RowBox[{"rGas", "\[Rule]", 
         RowBox[{"0.082057338", " ", 
          SuperscriptBox["10", 
           RowBox[{"-", "6"}]]}]}], ",", 
        RowBox[{"tK", "\[Rule]", "298"}], ",", 
        RowBox[{"vG", "\[Rule]", 
         RowBox[{"4.74", "/", "1000"}]}]}], "}"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"c", "[", "t", "]"}], ",", 
       RowBox[{"p", "[", "t", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "10"}], "}"}]}], "]"}], "\[LeftDoubleBracket]",
    "1", "\[RightDoubleBracket]"}]}]], "Input",
 CellLabel->"In[16]:=",ExpressionUUID->"ded5bf35-51c1-4b15-a419-22c5eee2201f"],


Cell[BoxData[
 RowBox[{
  RowBox[{"doData", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
      "doData", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], "/.", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x_", ",", "y_"}], "}"}], "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"1000", 
          RowBox[{"y", "/", "32"}]}]}], "}"}]}]}], ",", 

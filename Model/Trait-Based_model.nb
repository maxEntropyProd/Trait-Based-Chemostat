Cell["\<\
Generate  a  legend based on the top maxLedgend based on both MCs\
\>", "Text",ExpressionUUID->"fffb2d82-3788-c04e-ae3b-3764fb1c93a3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"legendASVobs", "[", 
   RowBox[{
   "asvData_", ",", "minPer_", ",", "maxLedgend_", ",", "colorIndex_", ",", 
    "fontSize_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"asvDataRel", ",", "asvDataRelmin", ",", "tf", ",", "colors"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
      "Relative", " ", "abundance", " ", "of", " ", "an", " ", "ASV", " ", 
       "in", " ", "each", " ", "sample", " ", "time"}], ",", " ", 
      RowBox[{"gen", " ", "in", " ", "percentage"}]}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"asvDataRel", "=", 
      RowBox[{
       RowBox[{"Prepend", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"100", 
            RowBox[{
             RowBox[{"asvData", "\[LeftDoubleBracket]", 
              RowBox[{";;", ",", "i"}], "\[RightDoubleBracket]"}], "/", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Total", "[", 
                 RowBox[{"asvData", "\[LeftDoubleBracket]", 
                  RowBox[{";;", ",", "i"}], "\[RightDoubleBracket]"}], "]"}], 
                "!=", "0"}], ",", 
               RowBox[{"Total", "[", 
                RowBox[{"asvData", "\[LeftDoubleBracket]", 
                 RowBox[{";;", ",", "i"}], "\[RightDoubleBracket]"}], "]"}], ",",
                "1"}], "]"}]}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "2", ",", 
             RowBox[{
              RowBox[{"Dimensions", "[", "asvData", "]"}], "\[LeftDoubleBracket]",
               "2", "\[RightDoubleBracket]"}]}], "}"}]}], "]"}], ",", 
         RowBox[{"asvData", "\[LeftDoubleBracket]", 
          RowBox[{";;", ",", "1"}], "\[RightDoubleBracket]"}]}], "]"}], 
       "\[Transpose]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "Any", " ", "ASV", " ", "less", " ", "than", " ", "minPer", " ", "is", 
        " ", "set", " ", "to", " ", 
        RowBox[{"zero", ".", " ", "Note"}]}], ",", " ", 
       RowBox[{"Chop", " ", "only", " ", "works", " ", "on", " ", "reals"}], ",",
        " ", 
       RowBox[{
       "not", " ", "integers", " ", "or", " ", "rational", " ", "numbers"}]}],
       "*)"}], "\[IndentingNewLine]", 
     RowBox[{"asvDataRelmin", "=", 
      RowBox[{"Chop", "[", 
       RowBox[{
        RowBox[{"N", "[", "asvDataRel", "]"}], ",", "minPer"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "Get", " ", "a", " ", "vector", " ", "of", " ", "colors", " ", "based", 
       " ", "on", " ", "colorIndex", " ", "and", " ", "add", " ", "it", " ", 
       "as", " ", "the", " ", "first", " ", "column"}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"colors", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"ColorData", "[", "colorIndex", "]"}], "[", "i", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", 
          RowBox[{"Length", "[", "asvData", "]"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"asvDataRelmin", "=", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"Partition", "[", 
         RowBox[{"colors", ",", "1"}], "]"}], ",", "asvDataRelmin", ",", 
        "2"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "sort", " ", "asvDataRelmin", " ", "so", " ", "the", " ", "largest", " ",
        "are", " ", "first"}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"asvDataRelmin", "=", 
      RowBox[{"ReverseSortBy", "[", 
       RowBox[{"asvDataRelmin", ",", 
        RowBox[{
         RowBox[{"Max", "[", 
          RowBox[{"#", "\[LeftDoubleBracket]", 
           RowBox[{"3", ";;"}], "\[RightDoubleBracket]"}], "]"}], "&"}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"tf", "[", "p_", "]"}], ":=", 
      RowBox[{"TableForm", "[", 
       RowBox[{
        RowBox[{"Partition", "[", 
         RowBox[{
          RowBox[{"Flatten", "[", "p", "]"}], ",", 
          RowBox[{"UpTo", "[", "10", "]"}]}], "]"}], ",", 
        RowBox[{"TableSpacing", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"1", ",", "1"}], "}"}]}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"SwatchLegend", "[", 
      RowBox[{
       RowBox[{"asvDataRelmin", "\[LeftDoubleBracket]", 
        RowBox[{
         RowBox[{";;", "maxLedgend"}], ",", "1"}], "\[RightDoubleBracket]"}], 
       ",", 
       RowBox[{"asvDataRelmin", "\[LeftDoubleBracket]", 
        RowBox[{
         RowBox[{";;", "maxLedgend"}], ",", "2"}], "\[RightDoubleBracket]"}], 
       ",", 
       RowBox[{"LegendMarkerSize", "\[Rule]", "10"}], ",", 
       RowBox[{"LabelStyle", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"FontSize", "\[Rule]", "fontSize"}], "}"}]}], ",", 
       RowBox[{"LegendLayout", "->", "tf"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellLabel->
  "In[146]:=",ExpressionUUID->"a132e7c6-1316-f542-b82a-88c73047548b"],

Cell["Top  ASVs  for  both  MCs", "Text",ExpressionUUID->"9df66dfc-e26c-d34e-9871-855e35fb0f1c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"legendFamilyTop30", "=", 
  RowBox[{"legendASVobs", "[", 
   RowBox[{
    RowBox[{"Join", "[", 
     RowBox[{"familyMC1", ",", 
      RowBox[{"familyMC2", "\[LeftDoubleBracket]", 
       RowBox[{";;", ",", 
        RowBox[{"Range", "[", 
         RowBox[{"3", ",", "16"}], "]"}]}], "\[RightDoubleBracket]"}], ",", 
      "2"}], "]"}], ",", "0.1", ",", "30", ",", "24", ",", "10"}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[147]:=",ExpressionUUID->"830e6cf8-ac0c-1f4a-9578-e4dcbf46d4aa"],


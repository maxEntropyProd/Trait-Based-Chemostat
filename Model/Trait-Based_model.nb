Cell["Look at including all ASVs", "Text",ExpressionUUID->"dee568c2-73bb-409a-8be2-d178066b09b7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Rasterize", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"asvUniformRelGT0", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"uniformASVsRel", ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Max", "[", 
           RowBox[{"#", "\[LeftDoubleBracket]", 
            RowBox[{"2", ";;"}], "\[RightDoubleBracket]"}], "]"}], ">", "0"}],
          ")"}], "&"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"ListLinePlot", "[", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"times", ",", 
           RowBox[{"asvUniformRelGT0", "\[LeftDoubleBracket]", 
            RowBox[{"i", ",", 
             RowBox[{"2", ";;"}]}], "\[RightDoubleBracket]"}]}], "}"}], 
         "\[Transpose]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", 
          RowBox[{"Length", "[", "asvUniformRelGT0", "]"}]}], "}"}]}], "]"}], 
      ",", 
      RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], ",", 
   RowBox[{"LightDark", "->", "\"\<Light\>\""}]}], "]"}]], "Input",

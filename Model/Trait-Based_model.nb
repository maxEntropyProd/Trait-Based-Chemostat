Cell["\<\
Plot absolute ASV concentrations and relative abundance at the experimental \
sample times as a bar plot at the 0.1% relative abundance or greater.\
\>", "Text",ExpressionUUID->"1042661d-fdc3-41ef-aa04-489819445626"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"asvMinAbunRel", "=", "0.1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"asvUniformMin", "=", 
    RowBox[{"Chop", "[", 
     RowBox[{
      RowBox[{"N", "[", "uniformASVsRel", "]"}], ",", "asvMinAbunRel"}], 
     "]"}]}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "this", " ", "sets", " ", "any", " ", "ASV", " ", "that", " ", "is"}], 
    " ", "<", " ", 
    RowBox[{"asvMinAbunRel", " ", "to", " ", "0"}]}], " ", "*)"}]}]}], "Input",
 CellLabel->"In[64]:=",ExpressionUUID->"34a0a265-37de-4527-8bb7-7e463633d5e2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Rasterize", "[", 
  RowBox[{
   RowBox[{"GraphicsRow", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Plot", "[", 
        RowBox[{
         RowBox[{"Evaluate", "[", 
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"x", "[", "i", "]"}], "[", "t", "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1", ",", "500"}], "}"}]}], "]"}], "/.", 
           "soln500"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "0.71", ",", "24"}], "}"}], ",", 
         RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
         RowBox[{"Frame", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"True", ",", "False"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"True", ",", "False"}], "}"}]}], "}"}]}], ",", 
         RowBox[{"FrameLabel", "\[Rule]", 
          RowBox[{"{", 
           
           RowBox[{"\"\<\!\(\*StyleBox[\"Time\",FontColor->GrayLevel[0]]\)\!\(\
\*StyleBox[\" \
\",FontColor->GrayLevel[0]]\)\!\(\*StyleBox[\"(\",FontColor->GrayLevel[0]]\)\!\
\(\*StyleBox[\"d\",FontColor->GrayLevel[0]]\)\!\(\*StyleBox[\")\",FontColor->\
GrayLevel[0]]\)\>\"", 
            ",", "\"\<\!\(\*StyleBox[SubscriptBox[\"x\", \
\"i\"],FontColor->GrayLevel[0]]\)\!\(\*StyleBox[\"(\",FontColor->GrayLevel[0]]\
\)\!\(\*StyleBox[\"t\",FontColor->GrayLevel[0]]\)\!\(\*StyleBox[\")\",\
FontColor->GrayLevel[0]]\)\!\(\*StyleBox[\" \",FontColor->GrayLevel[0]]\)\!\(\
\*StyleBox[\"concentration\",FontColor->GrayLevel[0]]\)\!\(\*StyleBox[\" \
\",FontColor->GrayLevel[0]]\)\!\(\*StyleBox[\"(\",FontColor->GrayLevel[0]]\)\!\
\(\*StyleBox[\"\[Mu]M\",FontColor->GrayLevel[0]]\)\!\(\*StyleBox[\")\",\
FontColor->GrayLevel[0]]\)\>\""}], "}"}]}], ",", 
         RowBox[{"LabelStyle", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"Bold", ",", 
            RowBox[{"FontFamily", "\[Rule]", "\"\<Arial\>\""}], ",", 
            RowBox[{"FontSize", "\[Rule]", "16"}], ",", 
            RowBox[{"FontColor", "->", "Black"}]}], "}"}]}], ",", 
         RowBox[{"FrameStyle", "->", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Directive", "[", 
               RowBox[{"Thick", ",", "Black"}], "]"}], ",", "None"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Directive", "[", 
               RowBox[{"Thick", ",", "Black"}], "]"}], ",", "None"}], "}"}]}],
            "}"}]}], ",", 
         RowBox[{"PlotStyle", "\[Rule]", "Thick"}], ",", 
         RowBox[{"Epilog", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"Text", "[", 
            RowBox[{
             RowBox[{"Style", "[", 
              RowBox[{"\"\<A\>\"", ",", "Bold", ",", 
               RowBox[{"FontFamily", "\[Rule]", "\"\<Arial\>\""}], ",", 
               RowBox[{"FontSize", "\[Rule]", "16"}]}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"2", ",", "3.6"}], "}"}]}], "]"}], "}"}]}]}], "]"}], ",",
        "\[IndentingNewLine]", 
       RowBox[{"BarChart", "[", 
        RowBox[{

Cell[CellGroupData[{

Cell["Governing Equations for Trait-Based Model", "Section",ExpressionUUID->"c6d45a40-3e45-441b-9067-b1047e27acba"],

Cell[CellGroupData[{

Cell["Adaptive Monod Kinetics", "Subsection",ExpressionUUID->"2e3382d2-530b-4b72-874d-d31c33e2e50f"],

Cell[TextData[{
 "The adaptive Monod equation, written as the specific substrate uptake rate, \
",
 Cell[BoxData[
  FormBox["v", TraditionalForm]],ExpressionUUID->
  "e70ba533-b50c-a64b-a4e9-28aa828f0c78"],
 ", not the specific growth rate; that is, \[Mu] = \[Epsilon]v.  Standard \
parameters are used here. This function chooses along a continuum from \
gleaners (\[Epsilon] \[RightArrow] 0) to opportunists (\[Epsilon] \
\[RightArrow]0.7). Note, as \[Epsilon] exceeds 0.77, uptake rate decreases \
due to loss of thermodynamic drive (i.e., growth  reaction approaching \
equilibrium). Also see Vallino & Huber (2018) doi: ",
 ButtonBox["10.3389/fenvs.2018.00100",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.3389/fenvs.2018.00100"], None},
  ButtonNote->"https://doi.org/10.3389/fenvs.2018.00100"],
 "0"
}], "Text",ExpressionUUID->"6ba40ccb-9452-4e13-8e4f-47b0b24b59e8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"v", "[", 
   RowBox[{"s_", ",", "\[Epsilon]_"}], "]"}], ":=", " ", 
  RowBox[{"vM", " ", 
   SuperscriptBox["\[Epsilon]", "2"], " ", 
   FractionBox["s", 
    RowBox[{"s", "+", 
     RowBox[{"kM", " ", 
      SuperscriptBox["\[Epsilon]", "4"]}]}]], 
   RowBox[{"(", 
    RowBox[{"1", "-", 
     SuperscriptBox["\[Epsilon]", "2"]}], ")"}]}]}]], "Input",
 CellLabel->"In[29]:=",ExpressionUUID->"aa602cbd-d4d8-4aa5-a6bc-c877c48d8be9"],

Cell[TextData[{
 "The adaptive Monod equation gives the following family of curves for \
different values of \[Epsilon] for the standard values of vM (350 ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["d", 
    RowBox[{"-", "1"}]], TraditionalForm]],ExpressionUUID->
  "208a68db-a84b-4291-81b0-53eee6419fdf"],
 ") and kM (5000 \[Mu]M)."
}], "Text",ExpressionUUID->"b645a15d-0e64-46f5-ac68-edc89c8671cb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{

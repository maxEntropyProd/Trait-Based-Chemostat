Cell[CellGroupData[{

Cell[TextData[{
 "Dissolved Oxygen Data for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["k", "L"], TraditionalForm]],ExpressionUUID->
  "d94f9ed7-9fbd-4643-af55-d172c46264a1"],
 " estimation"
}], "Subsection",ExpressionUUID->"f236642d-e486-47b5-a9f9-078d4fd89a12"],

Cell[TextData[{
 "This data is used to determine the liquid-side oxygen mass transfer \
velocity, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["k", "L"], TraditionalForm]],ExpressionUUID->
  "75983a49-15f1-4f26-858a-0ec940d05e4e"],
 " (see below). DO data was collected following sparging of the chemostat \
with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "2"], TraditionalForm]],ExpressionUUID->
  "e3514bc8-8d4b-46fa-a854-f72dd8163f75"],
 " gas. After sparging with N2, the gas flow was changed to air, and the \
chemostat headspace was quickly equilibrated with air using a small fan for a \
short time so that the gas overlying the water would be at atmospheric \
pressures (i.e., fixed boundary condition). Import the DO data:"
}], "Text",ExpressionUUID->"ce4394d7-b94b-4580-afff-e68a46ad8ae3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"o2DataN2", "=", 
   RowBox[{"Import", "[", "\"\<../Data/DO_N2toAir.dat\>\"", "]"}]}], 
  ";"}]], "Input",
 CellLabel->"In[12]:=",ExpressionUUID->"0f34eae2-aecd-44ca-b0f8-c635d206d40a"],


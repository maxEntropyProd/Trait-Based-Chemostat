Cell["Solve the 500 ASV ode equations for the uniform distribution", "Text",ExpressionUUID->"8484f112-324b-426d-942b-ec4eedda1bf7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"soln500", "=", 
   RowBox[{"solveODEs", "[", 
    RowBox[{"0.71", ",", "24", ",", "params", ",", "uniform1"}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->"In[48]:=",ExpressionUUID->"715dd269-ffd3-4fed-a2bf-83c0024be081"],

Cell["\<\
500 ASVs for the uniform distribution case  in absolute concentrations \
(\[Mu]M C).\
\>", "Text",ExpressionUUID->"608ce97f-66f2-445e-ba71-310b40abee16"],

Cell[CellGroupData[{


Cell["\<\
redefine the function with the standard values for the parameters set\
\>", "Text",ExpressionUUID->"a48f9627-1737-48f0-b624-1d39874e097d"],

Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{"v", "[", 
    RowBox[{"s_", ",", "\[Epsilon]_"}], "]"}], ":=", " ", 
   RowBox[{"350", " ", 
    SuperscriptBox["\[Epsilon]", "2"], " ", 
    FractionBox["s", 
     RowBox[{"s", "+", 
      RowBox[{"5000", " ", 
       SuperscriptBox["\[Epsilon]", "4"]}]}]], 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      SuperscriptBox["\[Epsilon]", "2"]}], ")"}]}]}], "*)"}]], "Input",
 CellChangeTimes->{{3.92719759725333*^9, 3.9271976034958*^9}},
 CellLabel->"In[31]:=",ExpressionUUID->"49a610d0-0274-42af-bdb1-6457e164b18c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Saturated Oxygen in saline water", "Subsection",ExpressionUUID->"5896c40d-55d3-4525-a45a-c615230d011e"],

Cell[TextData[{
 "This function, satO2, returns the oxygen concentration (in \[Mu]M) for a \
given temperature (K) and salinity (PSU) in equilibrium with air in seawater \
.  Reference Weiss1970 : (in ",
 ButtonBox["deep - sea research, 17 : 721 - 735",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1016/0011-7471(70)90037-9"], None},
  ButtonNote->"https://doi.org/10.1016/0011-7471(70)90037-9"],
 ") .  However, the modified version here, hO2, allows for different partial \
pressures of oxygen, and changes the temperature unit to K ."
}], "Text",ExpressionUUID->"3cc13f93-f4f5-4f9e-937b-5de0896ba05c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"satO2", "[", 
   RowBox[{"tK_", ",", "s_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"a1", "=", " ", 
       RowBox[{"-", "173.4292"}]}], ",", 
      RowBox[{"a2", "=", " ", "249.6339"}], ",", 
      RowBox[{"a3", "=", " ", "143.3483"}], ",", 
      RowBox[{"a4", " ", "=", " ", 
       RowBox[{"-", "21.8492"}]}], ",", 
      RowBox[{"b1", "=", " ", 
       RowBox[{"-", "0.033096"}]}], ",", 
      RowBox[{"b2", "=", " ", "0.014259"}], ",", 
      RowBox[{"b3", "=", " ", 
       RowBox[{"-", "0.0017"}]}], ",", 
      RowBox[{"mlToumole", " ", "=", " ", "44.62"}], ",", "t100"}], "}"}], ",",
     "\n", 
    RowBox[{
     RowBox[{"t100", " ", "=", " ", 
      FractionBox["tK", "100"]}], ";", "\n", 
     RowBox[{"mlToumole", "  ", 
      RowBox[{"Exp", "[", 
       RowBox[{"a1", " ", "+", " ", 
        FractionBox["a2", "t100"], " ", "+", " ", 
        RowBox[{"a3", "  ", 
         RowBox[{"Log", "[", "t100", "]"}]}], " ", "+", 
        RowBox[{"a4", "  ", "t100"}], " ", "+", " ", 
        RowBox[{"s", " ", 
         RowBox[{"(", 
          RowBox[{"b1", " ", "+", " ", 
           RowBox[{"b2", "  ", "t100"}], " ", "+", " ", 
           RowBox[{"b3", "  ", 
            SuperscriptBox["t100", "2"]}]}], ")"}]}]}], "]"}]}]}]}], "\n", 
   "]"}]}]], "Input",
 CellTags->"satO2",
 CellLabel->"In[32]:=",ExpressionUUID->"240e7123-e8f8-4a34-a35c-b660e1cb7120"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"satO2", "[", 
  RowBox[{"293.15", ",", "0"}], "]"}]], "Input",
 CellLabel->"In[33]:=",ExpressionUUID->"9d5ebf30-752f-4778-ba3d-f1ff9a1bd617"],

Cell[BoxData["283.40533823834636`"], "Output",
 CellChangeTimes->{3.92712273094561*^9, 3.927122779788555*^9, 
  3.927197689708372*^9, 3.927214064126705*^9, 3.927276061337974*^9, 
  3.927296115640873*^9, 3.9273634860194626`*^9, 3.9273750463748207`*^9, 
  3.930410552734999*^9, 3.9304136714355354`*^9, 3.9306621338273315`*^9, 
  3.952354702829321*^9, 3.9822499957710743`*^9, 3.982251303880211*^9, 
  3.9822517406058044`*^9},
 CellLabel->"Out[33]=",ExpressionUUID->"988d29c1-ae70-e04c-97fe-a043024568d3"]
}, Open  ]],

Cell["\<\
This can be used for different partial pressures of oxygen (i.e., not just \
atmospheric).  Also, if variables are passed to satO2, then the Exp term in \
satO2 is simplified, but this then leads to problems because of large and \
small number multiplication.  By ensuring the arguments are numbers, Exp will \
not be simplified which keeps this problem form occurring.\
\>", "Text",ExpressionUUID->"d2a386f2-6916-406f-b892-e6d4ff1c7244"],

Cell[BoxData[
 RowBox[{
  RowBox[{"hO2", "[", 
   RowBox[{
    RowBox[{"s_", "?", "NumberQ"}], ",", 
    RowBox[{"t_", "?", "NumberQ"}]}], "]"}], ":=", 
  RowBox[{
   RowBox[{"satO2", "[", 
    RowBox[{"t", ",", "s"}], "]"}], "/", "0.20946"}]}]], "Input",
 CellLabel->"In[34]:=",ExpressionUUID->"5f115adf-2a9f-47aa-97ad-e25643e5ccde"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"hO2", "[", 
   RowBox[{"3", ",", "298"}], "]"}], "0.20946"}]], "Input",
 CellLabel->"In[35]:=",ExpressionUUID->"d85cd269-1a3d-47d4-ad83-31afb6fd4092"],

Cell[BoxData["253.75711496186332`"], "Output",
 CellChangeTimes->{3.927122730964615*^9, 3.927122779816218*^9, 
  3.927197689726355*^9, 3.927214064148794*^9, 3.9272760613450546`*^9, 
  3.927296115661974*^9, 3.927363486046717*^9, 3.9273750464037495`*^9, 
  3.9304105527580833`*^9, 3.930413671459612*^9, 3.930662133858425*^9, 
  3.9523547028376675`*^9, 3.9822499957960567`*^9, 3.9822513038978825`*^9, 
  3.982251740609833*^9},
 CellLabel->"Out[35]=",ExpressionUUID->"de5d2dff-1fa0-1844-bd54-c2be3b8e8912"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Setup governing equations where the number of bacteria is specified and the \
\[Epsilon] trait is randomly selected from a specified distribution.\
\>", "Subsection",ExpressionUUID->"f31f4a18-6d7d-4cae-b0f7-aeef74b96f4c"],

Cell[TextData[{
 "The function ",
 StyleBox["generateODEs",
  FontSlant->"Italic"],
 " generates a set of ODEs based on the length of ranSample, where the latter \
is a list of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Epsilon]", "i"], TraditionalForm]],ExpressionUUID->
  "8523d03d-9d8a-4708-a517-c1e7fd6d0fdd"],
 " values chosen from an appropriate probability distribution (that is, \
ranSample is given).  The initial conditions for x[i][0] is set to 1/n, where \
n is the number of ASVs used and x[i] biomass of ASV i and has the units of \
\[Mu]M C. This version includes simple quadratic mortality weighted by total \
biomass for closure."
}], "Text",
 CellChangeTimes->{{3.9273750968356743`*^9, 
  3.9273751248968983`*^9}},ExpressionUUID->"d3933196-569a-4405-9e91-\
8dedc0530d13"],

Cell[BoxData[
 RowBox[{
  RowBox[{"generateODEs", "[", 
   RowBox[{"params_List", ",", "ranSample_List"}], "]"}], ":=", 
  RowBox[{"Flatten", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"x", "[", "i", "]"}], "'"}], "[", "t", "]"}], "\[Equal]", 
           RowBox[{
            RowBox[{"\[ScriptCapitalD]", 
             RowBox[{"(", 
              RowBox[{"0", "-", 
               RowBox[{
                RowBox[{"x", "[", "i", "]"}], "[", "t", "]"}]}], ")"}]}], "+", 
            RowBox[{
             RowBox[{"\[Epsilon]", "[", "i", "]"}], " ", 
             RowBox[{"v", "[", 
              RowBox[{
               RowBox[{"s", "[", "t", "]"}], ",", 
               RowBox[{"\[Epsilon]", "[", "i", "]"}]}], "]"}], 
             RowBox[{
              RowBox[{"x", "[", "i", "]"}], "[", "t", "]"}]}], "-", 
            RowBox[{"m", " ", 
             RowBox[{
              SuperscriptBox[
               RowBox[{
                RowBox[{"x", "[", "i", "]"}], "[", "t", "]"}], "3"], "/", 
              RowBox[{"Sum", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"x", "[", "i", "]"}], "[", "t", "]"}], ",", 
                RowBox[{"{", 
                 RowBox[{"i", ",", "1", ",", 
                  RowBox[{"Length", "[", "ranSample", "]"}]}], "}"}]}], 
               "]"}]}]}]}]}], " ", "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", 
           RowBox[{"Length", "[", "ranSample", "]"}]}], "}"}]}], "]"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"s", "'"}], "[", "t", "]"}], "\[Equal]", 
        RowBox[{
         RowBox[{"\[ScriptCapitalD]", 
          RowBox[{"(", 
           RowBox[{"s0", "-", 
            RowBox[{"s", "[", "t", "]"}]}], ")"}]}], "-", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"v", "[", 
             RowBox[{
              RowBox[{"s", "[", "t", "]"}], ",", 
              RowBox[{"\[Epsilon]", "[", "i", "]"}]}], "]"}], 
            RowBox[{
             RowBox[{"x", "[", "i", "]"}], "[", "t", "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", 
             RowBox[{"Length", "[", "ranSample", "]"}]}], "}"}]}], "]"}]}]}], 
       ",", "\[IndentingNewLine]", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"x", "[", "i", "]"}], "[", "0", "]"}], "\[Equal]", 
          RowBox[{"1", "/", 
           RowBox[{"Length", "[", "ranSample", "]"}]}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", 
           RowBox[{"Length", "[", "ranSample", "]"}]}], "}"}]}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"s", "[", "0", "]"}], "\[Equal]", "0"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"o2", "'"}], "[", "t", "]"}], "\[Equal]", 
        RowBox[{
         RowBox[{"\[ScriptCapitalD]", 
          RowBox[{"(", 
           RowBox[{"o2f", "-", 
            RowBox[{"o2", "[", "t", "]"}]}], ")"}]}], "+", 
         RowBox[{"kLO2", " ", "a", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"pO2", "[", "t", "]"}], 
              RowBox[{"hO2", "[", 
               RowBox[{"sal", ",", "tK"}], "]"}]}], "-", 
             RowBox[{"o2", "[", "t", "]"}]}], ")"}], "/", "vL"}]}], "-", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "-", 

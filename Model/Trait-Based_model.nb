Cell[CellGroupData[{

Cell["Beta distribution function Solution for MS", "Section",ExpressionUUID->"7eb0f167-5542-4886-845a-cdac70193ea6"],

Cell["\<\
This is basically the same as above, except \[Epsilon] is drawn from a beta \
probability distribution that is skewed towards oligotrophic growth \
characteristics.\
\>", "Text",ExpressionUUID->"7acc9b65-337f-4de5-805d-489e04bd7620"],

Cell[CellGroupData[{

Cell["Run with \[Alpha] = 1.1, \[Beta] = 13.3", "Subsubsection",ExpressionUUID->"315c7071-aa32-4f19-aaf3-5e9147c917f5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"params", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[ScriptCapitalD]", "\[Rule]", 
      RowBox[{"expDil", "[", 
       RowBox[{"t", ",", "50"}], "]"}]}], " ", 
     RowBox[{"(*", 
      SuperscriptBox["d", 
       RowBox[{"-", "1"}]], "*)"}], ",", "\[IndentingNewLine]", 
     RowBox[{"s0", "\[Rule]", "600"}], ",", 
     RowBox[{"(*", 
      RowBox[{"mmol", " ", 
       SuperscriptBox["m", 
        RowBox[{"-", "3"}]]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"pO2f", "\[Rule]", ".2106"}], ",", 
     RowBox[{"(*", "atm", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"sal", "\[Rule]", "3"}], ",", 
     RowBox[{"(*", "PSU", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"tK", "\[Rule]", "298.15"}], ",", 
     RowBox[{"(*", "K", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"o2f", "\[Rule]", 
      RowBox[{
       RowBox[{"hO2", "[", 
        RowBox[{"3", ",", "298.15"}], "]"}], ".21"}]}], ",", 
     RowBox[{"(*", 
      RowBox[{"mmol", " ", 
       SuperscriptBox["m", 
        RowBox[{"-", "3"}]]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"kLO2", "\[Rule]", "1.65"}], ",", " ", 
     RowBox[{"(*", 
      RowBox[{"m", " ", 
       SuperscriptBox["d", 
        RowBox[{"-", "1"}]]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"a", "\[Rule]", " ", 
      RowBox[{"\[Pi]", " ", 
       SuperscriptBox["0.114", "2"]}]}], ",", 
     RowBox[{"(*", 
      SuperscriptBox["m", "2"], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"rGas", "\[Rule]", 
      RowBox[{"0.082057338", " ", 
       SuperscriptBox["10", 
        RowBox[{"-", "6"}]]}]}], ",", 
     RowBox[{"(*", 

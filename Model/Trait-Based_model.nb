Cell["So a value of 50 for \[Sigma] works well.", "Text",ExpressionUUID->"42cceb85-842c-4240-9997-197c5ca39791"],

Cell["Function  for  bar charts", "Text",
 CellChangeTimes->{{3.927363544935604*^9, 
  3.9273635646908703`*^9}},ExpressionUUID->"638e7c95-a20d-b743-b89b-\
339fe4fbb2e0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"xiBarChart", "[", 
   RowBox[{"xiRel_List", ",", "labels_List", ",", "dBars_List", ",", "fig_"}],
    "]"}], ":=", 
  RowBox[{"BarChart", "[", 
   RowBox[{"xiRel", ",", 
    RowBox[{"ChartLayout", "\[Rule]", "\"\<Stacked\>\""}], ",", 
    RowBox[{"ChartLabels", "\[Rule]", "labels"}], ",", 
    RowBox[{"PlotRange", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0.5", ",", "14.5"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "100"}], "}"}]}], "}"}]}], ",", " ", 
    RowBox[{"LabelStyle", "\[Rule]", 
     RowBox[{"{", 

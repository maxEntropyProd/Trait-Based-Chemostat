Cell["\<\
Look at diversity using relative abundance, and sample at the same times \
points as the MC\[CloseCurlyQuote]s were. Note, because of the high \
diversity, the min ASV relative abundance must be set rather low, as no ASV \
reaches high rel abundance. Here, using 1% (that is, include any ASV that at \
any times exceeds 1% in abundance)\
\>", "Text",ExpressionUUID->"c8f466f9-0289-48e4-986a-6bdf73a6eaf5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"times", "=", 
    RowBox[{"{", 
     RowBox[{
     "0.8", ",", " ", "6.8", ",", " ", "9.5", ",", " ", "10.5", ",", " ", 
      "15.5", ",", " ", "16.5", ",", " ", "17.6", ",", " ", "18.8", ",", " ", 
      "19.8", ",", "21.5", ",", "21.8", ",", "22.4", ",", "22.8", ",", 
      "23.5"}], "}"}]}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"uniformASVs", "=", 
   RowBox[{
    RowBox[{"Prepend", "[", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"x", "[", "i", "]"}], "[", "t", "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1", ",", "500"}], "}"}]}], "]"}], "/.", 
           "soln500"}], "/.", 
          RowBox[{"t", "\[Rule]", 
           RowBox[{
           "times", "\[LeftDoubleBracket]", "j", 
            "\[RightDoubleBracket]"}]}]}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "1", ",", 
           RowBox[{"Length", "[", "times", "]"}]}], "}"}]}], "]"}], "]"}], ",", 
      RowBox[{"Evaluate", "[", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"\"\<ASV_\>\"", "<>", 
          RowBox[{"ToString", "[", "i", "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "500"}], "}"}]}], "]"}], "]"}]}], "]"}], 
    "\[Transpose]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"uniformASVsRel", "=", 
   RowBox[{
    RowBox[{"Prepend", "[", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"100", 
         RowBox[{
          RowBox[{"uniformASVs", "\[LeftDoubleBracket]", 
           RowBox[{
            RowBox[{"1", ";;"}], ",", "i"}], "\[RightDoubleBracket]"}], "/", 
          RowBox[{"Total", "[", 
           RowBox[{"uniformASVs", "\[LeftDoubleBracket]", 
            RowBox[{
             RowBox[{"1", ";;"}], ",", "i"}], "\[RightDoubleBracket]"}], 
           "]"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "2", ",", 
          RowBox[{
           RowBox[{"Dimensions", "[", "uniformASVs", "]"}], "\[LeftDoubleBracket]",
            "2", "\[RightDoubleBracket]"}]}], "}"}]}], "]"}], ",", 
      RowBox[{"uniformASVs", "\[LeftDoubleBracket]", 
       RowBox[{
        RowBox[{"1", ";;"}], ",", "1"}], "\[RightDoubleBracket]"}]}], "]"}], 
    "\[Transpose]"}]}], ";"}]}], "Input",
 CellLabel->"In[58]:=",ExpressionUUID->"e730b98b-db82-c343-b27e-d92f05836021"],

Cell["\<\
With  a  1 %  cutoff, there are not ASVs that make it to the end of the \
experiment\
\>", "Text",
 CellChangeTimes->{{3.9271984398604927`*^9, 
  3.927198474186699*^9}},ExpressionUUID->"de4322af-f66d-ed49-92bf-\
bae1843d0ed6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Rasterize", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"asvUniformRelGT1", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"uniformASVsRel", ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Max", "[", 
           RowBox[{"#", "\[LeftDoubleBracket]", 
            RowBox[{"2", ";;"}], "\[RightDoubleBracket]"}], "]"}], ">", "1"}],
          ")"}], "&"}]}], "]"}]}], ";", 
    RowBox[{"ListLinePlot", "[", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"times", ",", 
           RowBox[{"asvUniformRelGT1", "\[LeftDoubleBracket]", 
            RowBox[{"i", ",", 
             RowBox[{"2", ";;"}]}], "\[RightDoubleBracket]"}]}], "}"}], 
         "\[Transpose]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", 
          RowBox[{"Length", "[", "asvUniformRelGT1", "]"}]}], "}"}]}], "]"}], 
      ",", 
      RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], ",", 
   RowBox[{"LightDark", "->", "\"\<Light\>\""}]}], "]"}]], "Input",
 CellChangeTimes->{{3.927198423624119*^9, 3.927198430238533*^9}, {
   3.9304137965893555`*^9, 3.930413808238945*^9}, 3.9822523386470394`*^9},
 CellLabel->"In[62]:=",ExpressionUUID->"e863ac2c-beeb-4be3-905c-8bda1517ce8c"],


 CellChangeTimes->{3.9272876760153885`*^9, 3.9822535313264427`*^9},
 CellLabel->
  "Out[129]=",ExpressionUUID->"51b95f29-6c69-e74c-8aa7-51aa870135c3"]
}, Open  ]],

Cell["Get  the  ASV taxon names", "Text",ExpressionUUID->"f2dd2c7a-c20c-cb48-a93e-f637d2a297d8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"taxaNames", "=", 
   RowBox[{"asvData", "\[LeftDoubleBracket]", 
    RowBox[{";;", ",", 
     RowBox[{"{", 
      RowBox[{"29", ",", "30", ",", "31", ",", "32", ",", "33", ",", "34"}], 
      "}"}]}], "\[RightDoubleBracket]"}]}], ";"}]], "Input",
 CellLabel->
  "In[130]:=",ExpressionUUID->"1656fe94-bb30-e74a-a121-b0dae89616de"],

Cell["\<\
Add  Siders  ASV  data  as  time  \[OpenCurlyDoubleQuote]Siders\
\[CloseCurlyDoubleQuote]  to  each  dataset and specify when samples were \
collected in days, which are slightly different for each MC.\
\>", "Text",ExpressionUUID->"6c5ce969-a804-8041-a6b0-177b144ec87e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"timesMC1", "=", 
    RowBox[{"{", 
     RowBox[{"\"\<Siders\>\"", ",", "0.8", ",", " ", "10.5", ",", " ", "15.5",
       ",", " ", "16.5", ",", " ", "17.6", ",", " ", "18.8", ",", " ", "19.8",
       ",", "21.5", ",", "21.8", ",", "22.4", ",", "22.8", ",", "23.5"}], 
     "}"}]}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"timesMC2", "=", 
    RowBox[{"{", 
     RowBox[{"\"\<Siders\>\"", ",", "0.8", ",", " ", "6.8", ",", " ", "9.5", ",",
       " ", "10.5", ",", " ", "15.5", ",", " ", "16.5", ",", " ", "17.6", ",",
       " ", "18.8", ",", " ", "19.8", ",", "21.5", ",", "21.8", ",", "22.4", ",",
       "23.5"}], "}"}]}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"timesMC12", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<Siders\>\"", ",", "0.8", ",", " ", "6.8", ",", " ", "9.5", ",",
      " ", "10.5", ",", " ", "15.5", ",", " ", "16.5", ",", " ", "17.6", ",", 
     " ", "18.8", ",", " ", "19.8", ",", "21.5", ",", "21.8", ",", "22.4", ",",
      "22.8", ",", "23.5"}], "}"}]}], ";"}]}], "Input",
 CellLabel->
  "In[131]:=",ExpressionUUID->"08cb7aff-eff6-954b-8d85-ac07535b0ca3"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"asvMC1", "=", 
    RowBox[{"Table", "[", 
     RowBox[{"0", ",", 
      RowBox[{
       RowBox[{"Dimensions", "[", "asvData", "]"}], "\[LeftDoubleBracket]", 
       "1", "\[RightDoubleBracket]"}], ",", 
      RowBox[{
       RowBox[{"Length", "[", "timesMC12", "]"}], "+", "1"}]}], "]"}]}], 
   ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"initialize", " ", "these", " ", "to", " ", "0"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"asvMC2", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{
      RowBox[{"Dimensions", "[", "asvData", "]"}], "\[LeftDoubleBracket]", 
      "1", "\[RightDoubleBracket]"}], ",", 
     RowBox[{
      RowBox[{"Length", "[", "timesMC12", "]"}], "+", "1"}]}], "]"}]}], 
  ";"}]}], "Input",
 CellLabel->
  "In[134]:=",ExpressionUUID->"8f7ea50a-374e-1140-9d00-f1d5050f6e0d"],

Cell["\<\
Copy  in  the  asvData, but add in Siders\[CloseCurlyQuote] ASVs and keep \
columns 0 for where samples did not sequence.\
\>", "Text",ExpressionUUID->"2dc6af16-3a9b-dd42-9a09-fa704e086c1f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"asvMC1", "\[LeftDoubleBracket]", 
    RowBox[{";;", ",", 
     RowBox[{"Flatten", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2", ",", "3", ",", 
        RowBox[{"Range", "[", 
         RowBox[{"6", ",", "16"}], "]"}]}], "}"}], "]"}]}], 
    "\[RightDoubleBracket]"}], "=", 
   RowBox[{"asvData", "\[LeftDoubleBracket]", 
    RowBox[{";;", ",", 
     RowBox[{"Range", "[", 
      RowBox[{"1", ",", "14"}], "]"}]}], "\[RightDoubleBracket]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"asvMC2", "\[LeftDoubleBracket]", 
    RowBox[{";;", ",", 
     RowBox[{"Flatten", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Range", "[", 
         RowBox[{"1", ",", "14"}], "]"}], ",", "16"}], "}"}], "]"}]}], 
    "\[RightDoubleBracket]"}], "=", 
   RowBox[{"asvData", "\[LeftDoubleBracket]", 
    RowBox[{";;", ",", 
     RowBox[{"Flatten", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2", ",", 
        RowBox[{"Range", "[", 
         RowBox[{"15", ",", "27"}], "]"}]}], "}"}], "]"}]}], 
    "\[RightDoubleBracket]"}]}], ";"}]}], "Input",
 CellLabel->
  "In[136]:=",ExpressionUUID->"a1ee42df-83c5-7f4c-b335-3291953282b1"],

Cell["\<\
Define function to name and ASV based on columns in taxaNames above\
\>", "Text",ExpressionUUID->"b68d56d6-8431-5641-b56c-042be3087c7c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"nameMake", "[", 
   RowBox[{"n1_String", ",", "n2_String"}], "]"}], ":=", 
  RowBox[{"n1", "<>", "\"\< \>\"", "<>", "n2"}]}]], "Input",
 CellLabel->
  "In[138]:=",ExpressionUUID->"aa434e13-337d-044a-97ad-89a9fab1c1f6"],

Cell["\<\
Define  function for generating bar charts with a percentage cutoff. This  \
version  of plotASVobs sets ASVs with relative abundances less than minPer to \
zero instead of removing them. That way, ASV color indexes stay the same. \
maxLedgend specifies how many of the top ASV taxon names to display, and \
colorIndex is based on the Mathematica\[CloseCurlyQuote]s Indexed Color \
Palette Collections\
\>", "Text",ExpressionUUID->"de0e1945-730f-6648-9d70-2d280a78f527"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"plotASVobs", "[", 
    RowBox[{
    "asvData_", ",", "timePts_List", ",", "minPer_", ",", "maxLedgend_", ",", 
     "colorIndex_", ",", "dBars_List", ",", "fig_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"asvDataRel", ",", "asvDataRelmin", ",", "tf", ",", "colors"}], 
      "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "Relative", " ", "abundance", " ", "of", " ", "an", " ", "ASV", " ", 
        "in", " ", "each", " ", "sample", " ", "time"}], ",", " ", 
       RowBox[{"gen", " ", "in", " ", "percentage"}]}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"asvDataRel", "=", 
       RowBox[{
        RowBox[{"Prepend", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"100", 
             RowBox[{
              RowBox[{"asvData", "\[LeftDoubleBracket]", 
               RowBox[{";;", ",", "i"}], "\[RightDoubleBracket]"}], "/", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Total", "[", 
                  RowBox[{"asvData", "\[LeftDoubleBracket]", 
                   RowBox[{";;", ",", "i"}], "\[RightDoubleBracket]"}], "]"}],
                  "!=", "0"}], ",", 
                RowBox[{"Total", "[", 
                 RowBox[{"asvData", "\[LeftDoubleBracket]", 
                  RowBox[{";;", ",", "i"}], "\[RightDoubleBracket]"}], "]"}], 
                ",", "1"}], "]"}]}]}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "2", ",", 
              RowBox[{
               RowBox[{"Dimensions", "[", "asvData", "]"}], "\[LeftDoubleBracket]",
                "2", "\[RightDoubleBracket]"}]}], "}"}]}], "]"}], ",", 
          RowBox[{"asvData", "\[LeftDoubleBracket]", 
           RowBox[{";;", ",", "1"}], "\[RightDoubleBracket]"}]}], "]"}], 
        "\[Transpose]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
        "Any", " ", "ASV", " ", "less", " ", "than", " ", "minPer", " ", "is",
          " ", "set", " ", "to", " ", 
         RowBox[{"zero", ".", " ", "Note"}]}], ",", " ", 
        RowBox[{"Chop", " ", "only", " ", "works", " ", "on", " ", "reals"}], 
        ",", " ", 
        RowBox[{
        "not", " ", "integers", " ", "or", " ", "rational", " ", 
         "numbers"}]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"asvDataRelmin", "=", 
       RowBox[{"Chop", "[", 
        RowBox[{
         RowBox[{"N", "[", "asvDataRel", "]"}], ",", "minPer"}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Get", " ", "a", " ", "vector", " ", "of", " ", "colors", " ", "based",
         " ", "on", " ", "colorIndex", " ", "and", " ", "add", " ", "it", " ",
         "as", " ", "the", " ", "first", " ", "column"}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"colors", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"ColorData", "[", "colorIndex", "]"}], "[", "i", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"Length", "[", "asvData", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"asvDataRelmin", "=", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"Partition", "[", 
          RowBox[{"colors", ",", "1"}], "]"}], ",", "asvDataRelmin", ",", 
         "2"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "sort", " ", "asvDataRelmin", " ", "so", " ", "the", " ", "largest", " ",
         "are", " ", "first"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"asvDataRelmin", "=", 
       RowBox[{"ReverseSortBy", "[", 
        RowBox[{"asvDataRelmin", ",", 
         RowBox[{
          RowBox[{"Max", "[", 
           RowBox[{"#", "\[LeftDoubleBracket]", 
            RowBox[{"3", ";;"}], "\[RightDoubleBracket]"}], "]"}], "&"}]}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"tf", "[", "p_", "]"}], ":=", 
       RowBox[{"TableForm", "[", 
        RowBox[{
         RowBox[{"Partition", "[", 
          RowBox[{
           RowBox[{"Flatten", "[", "p", "]"}], ",", 
           RowBox[{"UpTo", "[", "10", "]"}]}], "]"}], ",", 
         RowBox[{"TableSpacing", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"1", ",", "1"}], "}"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"TableForm", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"BarChart", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"asvDataRelmin", "\[LeftDoubleBracket]", 
             RowBox[{";;", ",", 
              RowBox[{"3", ";;"}]}], "\[RightDoubleBracket]"}], 
            "\[Transpose]"}], ",", 
           RowBox[{"ChartLayout", "\[Rule]", "\"\<Stacked\>\""}], ",", 
           RowBox[{"ChartLabels", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{"timePts", ",", 
              RowBox[{"Table", "[", 
               RowBox[{"\"\<\>\"", ",", 
                RowBox[{"{", 
                 RowBox[{"Length", "[", "asvDataRelmin", "]"}], "}"}]}], 
               "]"}]}], "}"}]}], ",", 
           RowBox[{"PlotRange", "->", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"0.5", ",", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Dimensions", "[", "asvDataRelmin", "]"}], "\[LeftDoubleBracket]",
                   "2", "\[RightDoubleBracket]"}], "-", "1.5"}]}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"0", ",", "100"}], "}"}]}], "}"}]}], ",", " ", 
           RowBox[{"LabelStyle", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{"Bold", ",", 
              RowBox[{"FontFamily", "\[Rule]", "\"\<Arial\>\""}], ",", 
              RowBox[{"FontSize", "\[Rule]", "16"}], ",", 
              RowBox[{"FontColor", "->", "Black"}]}], "}"}]}], ",", 
           RowBox[{"ChartStyle", "\[Rule]", 
            RowBox[{"asvDataRelmin", "\[LeftDoubleBracket]", 
             RowBox[{";;", ",", "1"}], "\[RightDoubleBracket]"}]}], ",", 
           RowBox[{"FrameLabel", "\[Rule]", 
            RowBox[{"{", 
             
             RowBox[{"\"\<Time (d)\>\"", 
              ",", "\"\<ASV Rel. Abundance\!\(\*StyleBox[\" \
\",FontColor->GrayLevel[0]]\)(%)\>\""}], "}"}]}], ",", 
           RowBox[{"Frame", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"True", ",", "False"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"True", ",", "False"}], "}"}]}], "}"}]}], ",", 
           RowBox[{"FrameStyle", "->", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Directive", "[", 
                 RowBox[{"Thick", ",", "Black"}], "]"}], ",", "None"}], "}"}],
               ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Directive", "[", 
                 RowBox[{"Thick", ",", "Black"}], "]"}], ",", "None"}], 
               "}"}]}], "}"}]}], ",", 
           RowBox[{"ImagePadding", "->", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"All", ",", "All"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"All", ",", "30"}], "}"}]}], "}"}]}], ",", 
           RowBox[{"ImageSize", "->", "550"}], ",", 
           RowBox[{"Epilog", "->", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Text", "[", 
               RowBox[{
                RowBox[{"Style", "[", 
                 RowBox[{"fig", ",", "Bold", ",", 
                  RowBox[{"FontFamily", "\[Rule]", "\"\<Arial\>\""}], ",", 

Cell["\<\
Solve ODEs for 500 ASVs again, but using the sampled beta distribution.\
\>", "Text",ExpressionUUID->"7259d211-6a6c-45e0-8a0f-2978f2a15574"],

Cell[BoxData[
 RowBox[{
  RowBox[{"soln500beta", "=", 
   RowBox[{"solveODEs", "[", 
    RowBox[{"0.71", ",", "24", ",", "params", ",", "betaSample"}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->"In[87]:=",ExpressionUUID->"6794a542-cd32-4a5a-8522-f8c7a798beac"],

Cell["Plot  the  absolute  concentrations  over  time", "Text",ExpressionUUID->"58b695a8-8ecd-8148-8f84-7f965e6e8db8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Rasterize", "[", 
  RowBox[{
   RowBox[{"xiBetaPlot", "=", 
    RowBox[{"ListLinePlot", "[", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"t", ",", 
            RowBox[{
             RowBox[{"x", "[", "i", "]"}], "[", "t", "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "500"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"t", ",", "0.71", ",", "24", ",", "0.1"}], "}"}]}], "]"}], 
        "/.", "soln500beta"}], "]"}], ",", 
      RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
      RowBox[{"Frame", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"True", ",", "False"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"True", ",", "False"}], "}"}]}], "}"}]}], ",", 
      RowBox[{"FrameLabel", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"\"\<\!\(\*StyleBox[\"Time\",FontColor->GrayLevel[0]]\)\!\(\*\
StyleBox[\" \
\",FontColor->GrayLevel[0]]\)\!\(\*StyleBox[\"(\",FontColor->GrayLevel[0]]\)\!\
\(\*StyleBox[\"d\",FontColor->GrayLevel[0]]\)\!\(\*StyleBox[\")\",FontColor->\
GrayLevel[0]]\)\>\"", 
         ",", "\"\<\!\(\*StyleBox[SubscriptBox[\"x\", \
\"i\"],FontColor->GrayLevel[0]]\)\!\(\*StyleBox[\"(\",FontColor->GrayLevel[0]]\
\)\!\(\*StyleBox[\"t\",FontColor->GrayLevel[0]]\)\!\(\*StyleBox[\")\",\
FontColor->GrayLevel[0]]\)\!\(\*StyleBox[\" \",FontColor->GrayLevel[0]]\)\!\(\
\*StyleBox[\"concentration\",FontColor->GrayLevel[0]]\)\!\(\*StyleBox[\" \
\",FontColor->GrayLevel[0]]\)\!\(\*StyleBox[\"(\",FontColor->GrayLevel[0]]\)\!\
\(\*StyleBox[\"\[Mu]M\",FontColor->GrayLevel[0]]\)\!\(\*StyleBox[\")\",\
FontColor->GrayLevel[0]]\)\>\""}], "}"}]}], ",", 
      RowBox[{"LabelStyle", "\[Rule]", 

Cell["Observed ASV Data Plots", "Section",ExpressionUUID->"6136ab24-2cbe-4ab7-9f9d-26175a2ed48b"],

Cell["\<\
Import  all of the ASV data for MC1 and MC2, including taxa names and ASV \
data for Siders Pond which is in the file Table_S1_ASVs.csv in the Data \
subdirectory. Drop the header.\
\>", "Text",ExpressionUUID->"c8fb0e47-85c2-0d4c-9d9f-64c1dd0a456f"],

Cell[CellGroupData[{

Cell["Data  and plot function", "Subsection",
 CellChangeTimes->{{3.9272875902363396`*^9, 
  3.9272876164635487`*^9}},ExpressionUUID->"7289c07e-2679-8f40-80a5-\
cb4e392adbab"],

Cell[BoxData[
 RowBox[{
  RowBox[{"asvData", "=", 
   RowBox[{"Drop", "[", 
    RowBox[{
     RowBox[{"Import", "[", "\"\<..\\\\Data\\\\TableS1_ASVs.csv\>\"", "]"}], ",",
      "1"}], "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[128]:=",ExpressionUUID->"35def398-d405-bc42-a60d-98f17abe360e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Dimensions", "[", "asvData", "]"}]], "Input",

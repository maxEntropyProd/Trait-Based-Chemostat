Cell["\<\
This  is  an  older  version  of generateODEs that did not include quadratic \
mortality. This is not used in the current version and has been renamed to \
generateODEsOld \
\>", "Text",
 CellChangeTimes->{{3.927121247211447*^9, 
  3.927121321435013*^9}},ExpressionUUID->"aa9961da-05aa-ea4d-afde-\
50f27dc520e0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"generateODEsOld", "[", 
   RowBox[{"params_List", ",", "ranSample_List"}], "]"}], ":=", 
  RowBox[{"Flatten", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"x", "[", "i", "]"}], "'"}], "[", "t", "]"}], "\[Equal]", 
           RowBox[{
            RowBox[{"\[ScriptCapitalD]", 
             RowBox[{"(", 
              RowBox[{"0", "-", 
               RowBox[{
                RowBox[{"x", "[", "i", "]"}], "[", "t", "]"}]}], ")"}]}], "+", 
            RowBox[{
             RowBox[{"\[Epsilon]", "[", "i", "]"}], " ", 
             RowBox[{"v", "[", 
              RowBox[{
               RowBox[{"s", "[", "t", "]"}], ",", 
               RowBox[{"\[Epsilon]", "[", "i", "]"}]}], "]"}], 
             RowBox[{
              RowBox[{"x", "[", "i", "]"}], "[", "t", "]"}]}]}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", 
           RowBox[{"Length", "[", "ranSample", "]"}]}], "}"}]}], "]"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"s", "'"}], "[", "t", "]"}], "\[Equal]", 
        RowBox[{
         RowBox[{"\[ScriptCapitalD]", 
          RowBox[{"(", 
           RowBox[{"s0", "-", 
            RowBox[{"s", "[", "t", "]"}]}], ")"}]}], "-", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"v", "[", 
             RowBox[{
              RowBox[{"s", "[", "t", "]"}], ",", 
              RowBox[{"\[Epsilon]", "[", "i", "]"}]}], "]"}], 
            RowBox[{
             RowBox[{"x", "[", "i", "]"}], "[", "t", "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", 
             RowBox[{"Length", "[", "ranSample", "]"}]}], "}"}]}], "]"}]}]}], 
       ",", "\[IndentingNewLine]", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"x", "[", "i", "]"}], "[", "0", "]"}], "\[Equal]", 
          RowBox[{"1", "/", 
           RowBox[{"Length", "[", "ranSample", "]"}]}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", 
           RowBox[{"Length", "[", "ranSample", "]"}]}], "}"}]}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"s", "[", "0", "]"}], "\[Equal]", "0"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"o2", "'"}], "[", "t", "]"}], "\[Equal]", 
        RowBox[{
         RowBox[{"\[ScriptCapitalD]", 
          RowBox[{"(", 
           RowBox[{"o2f", "-", 
            RowBox[{"o2", "[", "t", "]"}]}], ")"}]}], "+", 
         RowBox[{"kLO2", " ", "a", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"pO2", "[", "t", "]"}], 
              RowBox[{"hO2", "[", 
               RowBox[{"sal", ",", "tK"}], "]"}]}], "-", 
             RowBox[{"o2", "[", "t", "]"}]}], ")"}], "/", "vL"}]}], "-", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "-", 
              RowBox[{"\[Epsilon]", "[", "i", "]"}]}], ")"}], 
            RowBox[{"v", "[", 
             RowBox[{
              RowBox[{"s", "[", "t", "]"}], ",", 
              RowBox[{"\[Epsilon]", "[", "i", "]"}]}], "]"}], 
            RowBox[{
             RowBox[{"x", "[", "i", "]"}], "[", "t", "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", 
             RowBox[{"Length", "[", "ranSample", "]"}]}], "}"}]}], "]"}]}]}], 
       ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"pO2", "'"}], "[", "t", "]"}], "\[Equal]", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"fG", 
            RowBox[{"(", 
             RowBox[{"pO2f", "-", 
              RowBox[{"pO2", "[", "t", "]"}]}], ")"}]}], "+", 
           RowBox[{"kLO2", " ", "a", " ", "rGas", " ", "tK", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"o2", "[", "t", "]"}], "-", 
              RowBox[{
               RowBox[{"pO2", "[", "t", "]"}], 
               RowBox[{"hO2", "[", 
                RowBox[{"sal", ",", "tK"}], "]"}]}]}], ")"}]}]}], ")"}], "/", 
         "vG"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"o2", "[", "0", "]"}], "\[Equal]", "o2f"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"pO2", "[", "0", "]"}], "==", "pO2f"}]}], "}"}], "/.", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Epsilon]", "[", "i", "]"}], "\[Rule]", 
        RowBox[{
        "ranSample", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]}],
        ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", 
         RowBox[{"Length", "[", "ranSample", "]"}]}], "}"}]}], "]"}]}], "/.", 
    "params"}], "]"}]}]], "Input",

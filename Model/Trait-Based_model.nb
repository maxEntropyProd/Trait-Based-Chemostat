Cell["Look at relative abundances", "Text",ExpressionUUID->"d8b8a7ec-3fe8-41b2-8e12-b680c3ec27e0"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"times", "=", 
    RowBox[{"{", 
     RowBox[{
     "0.8", ",", " ", "6.8", ",", " ", "9.5", ",", " ", "10.5", ",", " ", 
      "15.5", ",", " ", "16.5", ",", " ", "17.6", ",", " ", "18.8", ",", " ", 
      "19.8", ",", "21.5", ",", "21.8", ",", "22.4", ",", "22.8", ",", 
      "23.5"}], "}"}]}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"betaASVs", "=", 
   RowBox[{
    RowBox[{"Prepend", "[", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"x", "[", "i", "]"}], "[", "t", "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1", ",", "500"}], "}"}]}], "]"}], "/.", 
           "soln500beta"}], "/.", 
          RowBox[{"t", "\[Rule]", 
           RowBox[{
           "times", "\[LeftDoubleBracket]", "j", 
            "\[RightDoubleBracket]"}]}]}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "1", ",", 
           RowBox[{"Length", "[", "times", "]"}]}], "}"}]}], "]"}], "]"}], ",", 
      RowBox[{"Evaluate", "[", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"\"\<ASV_\>\"", "<>", 
          RowBox[{"ToString", "[", "i", "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "500"}], "}"}]}], "]"}], "]"}]}], "]"}], 
    "\[Transpose]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"betaASVsRel", "=", 
   RowBox[{
    RowBox[{"Prepend", "[", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"100", 
         RowBox[{
          RowBox[{"betaASVs", "\[LeftDoubleBracket]", 
           RowBox[{
            RowBox[{"1", ";;"}], ",", "i"}], "\[RightDoubleBracket]"}], "/", 
          RowBox[{"Total", "[", 
           RowBox[{"betaASVs", "\[LeftDoubleBracket]", 
            RowBox[{
             RowBox[{"1", ";;"}], ",", "i"}], "\[RightDoubleBracket]"}], 
           "]"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "2", ",", 
          RowBox[{
           RowBox[{"Dimensions", "[", "betaASVs", "]"}], "\[LeftDoubleBracket]",
            "2", "\[RightDoubleBracket]"}]}], "}"}]}], "]"}], ",", 
      RowBox[{"betaASVs", "\[LeftDoubleBracket]", 
       RowBox[{
        RowBox[{"1", ";;"}], ",", "1"}], "\[RightDoubleBracket]"}]}], "]"}], 
    "\[Transpose]"}]}], ";"}]}], "Input",
 CellLabel->"In[90]:=",ExpressionUUID->"2f85f463-91d6-4cbb-87b1-e212db3d0a3d"],

Cell["Plot  ASVs  that  have  a  relative  abundance > 5 %", "Text",ExpressionUUID->"0a640e78-8da8-4f4e-b114-365ffa15a51a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Rasterize", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"asvBetaRelGT5", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"betaASVsRel", ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Max", "[", 
           RowBox[{"#", "\[LeftDoubleBracket]", 
            RowBox[{"2", ";;"}], "\[RightDoubleBracket]"}], "]"}], ">", "5"}],
          ")"}], "&"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"ListLinePlot", "[", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"times", ",", 
           RowBox[{"asvBetaRelGT5", "\[LeftDoubleBracket]", 
            RowBox[{"i", ",", 
             RowBox[{"2", ";;"}]}], "\[RightDoubleBracket]"}]}], "}"}], 
         "\[Transpose]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", 
          RowBox[{"Length", "[", "asvBetaRelGT5", "]"}]}], "}"}]}], "]"}], ",", 
      RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], ",", 
   RowBox[{"LightDark", "->", "\"\<Light\>\""}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9304140811469193`*^9, 3.9304140831257*^9}, 
   3.9822531575753193`*^9},
 CellLabel->"In[93]:=",ExpressionUUID->"9563dd59-9a00-f64b-80ff-d36b3ce36eed"],


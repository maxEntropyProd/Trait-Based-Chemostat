Cell["\<\
Only dissolved oxygen significantly depends on kL. The headspace of the \
reactor is large compared to the gas flow rate; consequently, it takes a long \
time for the headspace to change concentration from 0 following sparging of \
the reactor with N2.\
\>", "Text",ExpressionUUID->"1fc7455a-0630-4d2c-a105-237c16f5238b"],

Cell[TextData[{
 "Change the experimental approach and model. Sparge the reactor with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "2"], TraditionalForm]],ExpressionUUID->
  "ae1e91ec-a9bf-4b47-9721-cdfb07d3ca21"],
 ". After the DO is low, rapidly exchange the gas headspace with air by using \
a small computer fan so the headspace ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["O", "2"], TraditionalForm]],ExpressionUUID->
  "b66a6700-bb1a-4e03-bed7-0a4bb2c46cfb"],
 " concentration rapidly equilibrates with the atmosphere. In this setup, \
modeling the oxygen partial pressure can be removed and only a model for DO \
is needed. Here p[t] is set to 0.21 atm."
}], "Text",ExpressionUUID->"5b6865df-6f37-4c3e-81ef-51bbe83220f7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"odes", "[", "input_List", "]"}], ":=", 
  RowBox[{
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"c", "'"}], "[", "t", "]"}], "\[Equal]", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"fL", 
          RowBox[{"(", 
           RowBox[{"cF", "-", 
            RowBox[{"c", "[", "t", "]"}]}], ")"}]}], "+", 
         RowBox[{"kL", " ", "a", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"p", "[", "t", "]"}], "h"}], "-", 
            RowBox[{"c", "[", "t", "]"}]}], ")"}]}]}], ")"}], "/", "vL"}]}], ",",
      "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"c", "[", "0", "]"}], "\[Equal]", "cF"}]}], "}"}], "/.", 
   "input"}]}]], "Input",
 CellLabel->"In[21]:=",ExpressionUUID->"6efac62a-7b79-40e1-8527-16d1b8aaedc9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"soln1", "=", 
  RowBox[{
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"odes", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"fL", "\[Rule]", "0"}], ",", 
        RowBox[{"cF", "\[Rule]", "0"}], ",", 
        RowBox[{"kL", "\[Rule]", ".13"}], ",", 
        RowBox[{"a", "\[Rule]", 
         RowBox[{"\[Pi]", " ", 
          SuperscriptBox["0.114", "2"]}]}], ",", 
        RowBox[{"h", "\[Rule]", 
         RowBox[{"hO2", "[", "298", "]"}]}], ",", 
        RowBox[{"vL", "\[Rule]", 
         RowBox[{"3", "/", "1000"}]}], ",", 
        RowBox[{"fG", "\[Rule]", 
         RowBox[{"1500.72", "/", "1000"}]}], ",", 
        RowBox[{"pF", "\[Rule]", "0.21"}], ",", 
        RowBox[{"rGas", "\[Rule]", 
         RowBox[{"0.082057338", " ", 
          SuperscriptBox["10", 
           RowBox[{"-", "6"}]]}]}], ",", 
        RowBox[{"tK", "\[Rule]", "298"}], ",", 
        RowBox[{"vG", "\[Rule]", 
         RowBox[{"4.74", "/", "1000"}]}], ",", 
        RowBox[{
         RowBox[{"p", "[", "t", "]"}], "\[Rule]", "0.21"}]}], "}"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"c", "[", "t", "]"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "10"}], "}"}]}], "]"}], "\[LeftDoubleBracket]",
    "1", "\[RightDoubleBracket]"}]}]], "Input",
 CellLabel->"In[22]:=",ExpressionUUID->"79882a00-7b94-492b-ba84-fd44e61d51f4"],


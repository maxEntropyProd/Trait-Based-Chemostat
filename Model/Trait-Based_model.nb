Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bacterialCounts", "=", 
  RowBox[{"ListLinePlot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"counts", "\[LeftDoubleBracket]", 
        RowBox[{
         RowBox[{"2", ";;"}], ",", 
         RowBox[{"{", 
          RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], 
        "\[RightDoubleBracket]"}], "/.", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x_", ",", "y_", ",", "z_"}], "}"}], "->", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"Around", "[", 
           RowBox[{
            RowBox[{
             SuperscriptBox["10", 
              RowBox[{"-", "6"}]], "y"}], ",", 
            RowBox[{
             SuperscriptBox["10", 
              RowBox[{"-", "6"}]], "z"}]}], "]"}]}], "}"}]}]}], ",", 
      RowBox[{
       RowBox[{"counts", "\[LeftDoubleBracket]", 
        RowBox[{
         RowBox[{"2", ";;"}], ",", 
         RowBox[{"{", 
          RowBox[{"1", ",", "4", ",", "5"}], "}"}]}], 
        "\[RightDoubleBracket]"}], "/.", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x_", ",", "y_", ",", "z_"}], "}"}], "->", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"Around", "[", 
           RowBox[{
            RowBox[{
             SuperscriptBox["10", 
              RowBox[{"-", "6"}]], "y"}], ",", 
            RowBox[{
             SuperscriptBox["10", 
              RowBox[{"-", "6"}]], "z"}]}], "]"}]}], "}"}]}]}]}], "}"}], ",", 
    RowBox[{"PlotMarkers", "\[Rule]", "Automatic"}], ",", 
    RowBox[{"Frame", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"True", ",", "False"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"True", ",", "False"}], "}"}]}], "}"}]}], ",", 
    RowBox[{"FrameLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\"\<Time (d)\>\"", 
       ",", "\"\<Bacteria (\!\(\*SuperscriptBox[\(10\), \(6\)]\) cells \
\!\(\*SuperscriptBox[\(mL\), \(-1\)]\))\>\""}], "}"}]}], ",", 
    RowBox[{"LabelStyle", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"Bold", ",", 
       RowBox[{"FontFamily", "\[Rule]", "\"\<Arial\>\""}], ",", 
       RowBox[{"FontSize", "\[Rule]", "16"}], ",", 
       RowBox[{"FontColor", "->", "Black"}]}], "}"}]}], ",", 
    RowBox[{"PlotRange", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "25"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "20"}], "}"}]}], "}"}]}], ",", 
    RowBox[{"ImageSize", "\[Rule]", "512"}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Thick", ",", "Blue"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Thick", ",", "Red"}], "}"}]}], "}"}]}], ",", 
    RowBox[{"FrameStyle", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Directive", "[", 
          RowBox[{"Thick", ",", "Black"}], "]"}], ",", "None"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Directive", "[", 

Cell["\<\
Define a function that numerically solves the generated set of ODEs over time \
from t0 to tf.  Note, experimental time is based on 00:00 30-Oct-2018.  The \
simulation \[OpenCurlyDoubleQuote]begins\[CloseCurlyDoubleQuote] when water \
was collected and placed into the collection container at about 17:00, or at \
t0 of 0.71 d.\
\>", "Text",ExpressionUUID->"f9ef15e1-7afa-4dec-b2a7-f7d49b969777"],

Cell[BoxData[
 RowBox[{
  RowBox[{"solveODEs", "[", 
   RowBox[{"t0_", ",", "tf_", ",", "params_List", ",", "ranSample_List"}], 
   "]"}], ":=", 
  RowBox[{
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{"generateODEs", "[", 
       RowBox[{"params", ",", "ranSample"}], "]"}], "]"}], ",", 
     RowBox[{"Evaluate", "[", 
      RowBox[{"Flatten", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"x", "[", "i", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", 
             RowBox[{"Length", "[", "ranSample", "]"}]}], "}"}]}], "]"}], ",",
          "s", ",", "o2", ",", "pO2"}], "}"}], "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "t0", ",", "tf"}], "}"}]}], "]"}], "\[LeftDoubleBracket]",
    "1", "\[RightDoubleBracket]"}]}]], "Input",
 CellLabel->"In[39]:=",ExpressionUUID->"5f753e64-0b3d-4031-909e-fb689b87011b"],

Cell[CellGroupData[{

Cell["\<\
Define function to capture the shifts in dilution rate to match Exp1\
\>", "Subsubsection",ExpressionUUID->"4cb3c319-4a6c-4261-8ead-fc822720fba7"],

Cell["\<\
First define a smooth and continuous step function, where the steepness of \
the function is given by \[Sigma].  As \[Sigma] approaches  \[Infinity], the \
step function approaches a perfect step, which produces discontinuities at \
the steps that we wish to avoid for numerical reasons. A little trial and \
error was used to figure out what a reasonable value of \[Sigma] should be.\
\>", "Text",ExpressionUUID->"93f8e455-30b6-4094-9429-650e0abbc9ae"],

Cell[BoxData[
 RowBox[{
  RowBox[{"stepFcn", "[", 
   RowBox[{"t_", ",", "tm_", ",", "\[Sigma]_"}], "]"}], ":=", 
  FractionBox["1", 
   RowBox[{"1", "+", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "\[Sigma]"}], 
      RowBox[{"(", 
       RowBox[{"t", "-", "tm"}], ")"}]}], "]"}]}]]}]], "Input",
 PageWidth:>WindowWidth,
 CellLabel->"In[40]:=",ExpressionUUID->"2a8c6f7b-ab87-48bf-9da8-1aa549b64254"],

Cell["\<\
Then add these together to get the three dilution rates at the experimental \
step times of 0.84, 15.5 and 20.77 days.\
\>", "Text",ExpressionUUID->"351e936d-0914-4388-9a62-39aa06b986c5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"expDil", "[", 
   RowBox[{"t_", ",", "\[Sigma]_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"stepFcn", "[", 
     RowBox[{"t", ",", "0.84", ",", "\[Sigma]"}], "]"}], "/", "10"}], "+", 
   RowBox[{
    FractionBox["9", "10"], 
    RowBox[{"stepFcn", "[", 
     RowBox[{"t", ",", "15.5", ",", "\[Sigma]"}], "]"}]}], "+", 
   RowBox[{"9", 
    RowBox[{"stepFcn", "[", 
     RowBox[{"t", ",", "20.77", ",", "\[Sigma]"}], "]"}]}]}]}]], "Input",
 CellLabel->"In[41]:=",ExpressionUUID->"029f1203-c907-4dfc-bba8-a52598a51bf1"],

Cell["Here' s what that function looks like over 25 days.", "Text",ExpressionUUID->"b2e13224-1025-4810-a8b6-0f5e8cd24ea2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"expDil", "[", 
    RowBox[{"t", ",", "50"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "25"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]], "Input",
 CellLabel->"In[42]:=",ExpressionUUID->"0bce5ab2-6ab5-474c-8b93-33d268402538"],


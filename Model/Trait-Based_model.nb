plots  have  a  lot  of  elements\
\>", "Text",ExpressionUUID->"08b4a537-b7ff-184f-84df-cebfa0e56867"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Charting`$InteractiveHighlighting", "=", "False"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SetOptions", "[", 
   RowBox[{"Plot", ",", 
    RowBox[{"PlotHighlighting", "->", "None"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SetOptions", "[", 
   RowBox[{"ListPlot", ",", 
    RowBox[{"PlotHighlighting", "->", "None"}]}], "]"}], ";"}]}], "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"6e8d7f6d-89ba-4149-bd98-399e184c0943"],

Cell["\<\
Plot  sometimes  needs more recursion than the default, so set it higher here\
\>", "Text",ExpressionUUID->"88411aad-bf31-3648-bdcf-8ff469f748ed"],

